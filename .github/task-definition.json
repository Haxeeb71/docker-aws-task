{
  "family": "docker-aws-task-family",
  "networkMode": "bridge",
  "containerDefinitions": [
    {
      "name": "app",
      "image": "559198857091.dkr.ecr.us-east-1.amazonaws.com/docker-aws-task",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "DB_HOST", "value": "database-1.cm5002au0xsb.us-east-1.rds.amazonaws.com" },
        { "name": "DB_USER", "value": "admin" },
        { "name": "DB_PASSWORD", "value": "mariadb11" },
        { "name": "DB_NAME", "value": "database-1" }
      ],
      "cpu": 256,
      "memory": 512
    }
  ],
  "requiresCompatibilities": [
    "EC2"
  ]
}
